## 本機後端代理用（不要提交 .env）
## 複製為 .env 後填入實際值

# Mouser Order History API Key (UUID)
MOUSER_API_KEY=
# Mouser API version（預設 1.0）
MOUSER_API_VERSION=1.0

# DigiKey OAuth（2-legged / client_credentials）
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# DigiKey Account ID（通常為必填，取決於你的 OAuth 使用方式）
DIGIKEY_ACCOUNT_ID=

# 伺服器 Port（預設 8787）
PORT=8787

